# Required when live fax sending is enabled
TELNYX_API_KEY=
TELNYX_FAX_CONNECTION_ID=
TELNYX_FAX_FROM_NUMBER=

# Public URL where Telnyx can fetch /test-fax.pdf and post webhooks.
# For production this should be your domain, such as https://faxtest.example.com
SITE_URL=http://localhost:3000

# Defaults to true unless all required Telnyx variables are present.
# Set to false in Railway after variables are configured.
DRY_RUN=true

# Optional
PORT=3000
RATE_LIMIT_PER_DAY=10
ADS_ENABLED=false
ADSENSE_CLIENT_ID=
ADSENSE_SLOT_RECT=
